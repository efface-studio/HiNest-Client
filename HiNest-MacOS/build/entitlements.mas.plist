<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mac App Store 필수: App Sandbox 활성화 -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- 원격 웹앱(https://nest.hi-vits.com) 로드를 위한 아웃바운드 네트워크 -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- 파일 업로드/다운로드 — 업로드는 파일 선택기, 다운로드는 저장 다이얼로그
         (will-download 의 setSaveDialogOptions)라 user-selected 하나로 충분.
         downloads.read-write 는 대응 기능이 없어 2.4.5(i) 반려(1.0.0(3)) → 제거. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- App Store 배포 식별자 — 프로비저닝 프로파일과 일치해야 함.
         3NVCLTSP9V = 팀 ID (기존 Developer ID 서명 identity 에서 확인). -->
    <key>com.apple.application-identifier</key>
    <string>3NVCLTSP9V.com.hivits.hinest</string>
    <key>com.apple.developer.team-identifier</key>
    <string>3NVCLTSP9V</string>
</dict>
</plist>

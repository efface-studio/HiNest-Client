# =============================================================================
# HiNest 서버 환경 변수 샘플
# 실제 배포 시에는 이 파일을 `.env` 로 복사하고 값 채워넣기.
# .env 는 gitignore 됨 — 절대 커밋하지 말 것.
# =============================================================================

# 기본 실행 환경
NODE_ENV=development
PORT=4000

# 클라이언트(Vite) origin — CORS 화이트리스트
# 프로덕션에선 실제 Vercel 도메인으로 교체 (예: https://hinest.vercel.app)
CLIENT_ORIGIN=http://localhost:1000

# -----------------------------------------------------------------------------
# Supabase Postgres
# -----------------------------------------------------------------------------
# Supabase Dashboard → Settings → Database → Connection string
# 두 URL 이 필요:
#   - DATABASE_URL : 런타임용 (pgBouncer transaction mode, 포트 6543)
#                    → Prisma 가 짧게 connection 맺고 끊음
#   - DIRECT_URL   : 마이그레이션용 (direct, 포트 5432)
#                    → prisma migrate 가 세션 유지 필요
#
# 예시 (Supabase 가 제공하는 포맷):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# JWT — 16자 이상 필수. 프로덕션은 반드시 랜덤하게.
# 생성 예:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# -----------------------------------------------------------------------------
JWT_SECRET=

# 개발 중에만, 위 JWT_SECRET 이 비어도 기동 허용하려면 1 로.
# 프로덕션 배포엔 절대 설정하지 말 것.
# ALLOW_DEV_JWT_SECRET=1

# -----------------------------------------------------------------------------
# 서비스 계정 비밀번호 암호화 키 — 설정 안 하면 비번 저장 기능 자체가 비활성.
# base64 로 32바이트 권장:  openssl rand -base64 32
# 키가 바뀌면 기존에 저장된 비번은 복호화 불가 — 반드시 안전한 비밀 관리자에 보관.
# -----------------------------------------------------------------------------
ACCOUNT_ENC_KEY=

# -----------------------------------------------------------------------------
# AWS S3 — 파일 업로드 저장소 (primary, 2026-04 이관 후)
# -----------------------------------------------------------------------------
# IAM 콘솔에서 서버 전용 사용자 만들고 (예: hinest-server) AmazonS3FullAccess 부여.
# 추후 해당 버킷만 접근하도록 좁힌 커스텀 정책으로 교체 권장.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3 콘솔에서 미리 생성. 퍼블릭 액세스는 전부 차단 (서버 프록시 다운로드 구조).
S3_BUCKET=hinest-uploads-prod

# -----------------------------------------------------------------------------
# AWS SES — 메일 발송 (급여명세서 PDF 첨부, 비밀번호 재설정 등)
# -----------------------------------------------------------------------------
# 발신 주소. 반드시 SES(ap-northeast-2)에서 verify 된 도메인/이메일이어야 함.
# 도메인(nest.hi-vits.com)을 verify 했으면 그 도메인의 아무 주소나 사용 가능(메일함 불필요).
# IAM 사용자(hinest-server)에 ses:SendRawEmail / ses:SendEmail 권한 필요.
# 미설정 시 메일 발송 기능 비활성 — 발송 시 502 반환.
# 표시이름은 ASCII 권장 (From 헤더는 RFC2047 인코딩 안 함).
# 예: SES_FROM_ADDRESS="HiNest <no-reply@nest.hi-vits.com>"
SES_FROM_ADDRESS=

# -----------------------------------------------------------------------------
# Supabase Storage — 레거시 fallback (마이그레이션 기간 동안만 유지)
# -----------------------------------------------------------------------------
# S3 에 아직 복사되지 않은 과거 파일 다운로드용. 1~2주 지켜본 뒤 제거 가능.
# Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=hinest-uploads

# -----------------------------------------------------------------------------
# 개발자 콘솔 — 사내톡 감사 잠금 해제 비밀번호
# -----------------------------------------------------------------------------
# 개발자 콘솔의 \`chat log\` 명령으로 사내톡 감사 탭을 열 때 사용.
# 미설정 시 기능이 503 으로 비활성화돼 안전.
# 평문이라 로테이션 가능 — 길이 16+ 권장.
CHAT_AUDIT_PW=
